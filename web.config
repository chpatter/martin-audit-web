<?xml version="1.0" encoding="UTF-8"?>
<!--
  Martin Audit System — IIS Configuration (iisnode)

  IIS site root: C:\inetpub\martin-audit-app (project root, NOT build/)

  How it works:
    1. IIS authenticates users via Windows Auth (Kerberos or NTLM)
    2. iisnode runs Node.js inside IIS — auth is already done, username is available
    3. /api/* requests go to Node.js via iisnode
    4. Static files served from build/ subfolder
    5. SPA fallback to build/index.html

  Prerequisites:
    - IIS URL Rewrite module
    - iisnode installed (https://github.com/azure/iisnode/releases)
    - Windows Authentication enabled on the site
    - Anonymous Authentication disabled on the site
    - IIS site points to the PROJECT ROOT, not build/
-->
<configuration>
  <system.webServer>

    <!-- iisnode handler — routes matched requests to Node.js -->
    <handlers>
      <add name="iisnode" path="server/index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Block direct access to server files, node_modules, .env -->
        <rule name="Block Sensitive" stopProcessing="true">
          <match url="^(server/(?!index\.js)|node_modules/|\.env)" />
          <action type="CustomResponse" statusCode="403" />
        </rule>

        <!-- API requests → Node.js via iisnode -->
        <rule name="API" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="server/index.js" />
        </rule>

        <!-- Static files from build/ subfolder -->
        <rule name="Static Files" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{APPL_PHYSICAL_PATH}build\{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="build/{R:1}" />
        </rule>

        <!-- SPA fallback — React Router handles client-side routes -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/api/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/server/" negate="true" />
          </conditions>
          <action type="Rewrite" url="build/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode config — promote AUTH_USER so Node.js can read it -->
    <iisnode promoteServerVars="AUTH_USER" />

    <!-- Static file MIME types -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <directoryBrowse enabled="false" />

  </system.webServer>
</configuration>
